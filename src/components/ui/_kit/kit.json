{
  "$schema": "https://triesap.github.io/leptos_ui_kit/schema/0.9.0-alpha/kit.schema.json",
  "schemaVersion": "0.9.0-alpha",
  "tool": {
    "package": "leptos_ui_kit_cli",
    "binary": "leptos_ui_kit",
    "source": {
      "kind": "git",
      "url": "https://github.com/triesap/leptos_ui_kit",
      "rev": "0b4dc59139a73294a02a95d47f571f87a0d0e077"
    }
  },
  "project": {
    "kind": "single-crate-trunk-csr",
    "crateRoot": ".",
    "srcDir": "src",
    "indexHtml": "index.html"
  },
  "leptos": {
    "version": "0.9.0-alpha",
    "routerVersion": "0.9.0-alpha",
    "renderMode": "csr"
  },
  "install": {
    "uiDir": "src/components/ui",
    "uiMod": "src/components/ui/mod.rs",
    "componentsMod": "src/components/mod.rs"
  },
  "styles": {
    "mode": "pure-css",
    "css": "styles/kit.css"
  },
  "registry": {
    "source": "builtin"
  },
  "items": [
    {
      "name": "button",
      "source": "builtin"
    }
  ]
}
